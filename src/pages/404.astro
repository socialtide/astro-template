---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import { Home, ArrowLeft } from "@lucide/astro";
---

<BaseLayout
  title="404 - Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <Header />
  
  <main class="flex min-h-[60vh] items-center">
    <div class="container">
      <div class="mx-auto max-w-2xl text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-primary-600">
          404 Error
        </p>
        <h1 class="typography-display mb-4 text-gray-900">
          Page Not Found
        </h1>
        <p class="typography-body-large mb-8 text-gray-600">
          Sorry, we couldn't find the page you're looking for. It might have been moved or deleted.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
          <a href="/" class="btn-primary group">
            <Home class="mr-2 h-4 w-4" />
            Go to Homepage
          </a>
          <button
            onclick="history.back()"
            class="btn-secondary group"
          >
            <ArrowLeft class="mr-2 h-4 w-4" />
            Go Back
          </button>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>