---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import ContactForm from "../components/common/ContactForm.astro";
import { Mail, Phone, MapPin } from "@lucide/astro";
import siteData from "../data/site.json";
---

<BaseLayout
  title="Contact Us | Get in Touch"
  description="Ready to get started? Contact us today to discuss how we can help your business grow."
>
  <Header />

  <main>
    <!-- Contact Header -->
    <section class="bg-gray-50 py-12">
      <div class="container">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="typography-heading mb-4 text-gray-900">Get in Touch</h1>
          <p class="typography-body-large text-gray-600">
            We'd love to hear from you. Send us a message and we'll respond as
            soon as possible.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="section-spacing">
      <div class="container">
        <div class="grid gap-12 lg:grid-cols-3">
          <!-- Contact Information -->
          <div class="lg:col-span-1">
            <h2 class="mb-6 text-2xl font-semibold text-gray-900">
              Contact Information
            </h2>

            <div class="space-y-6">
              <div class="flex items-start">
                <div
                  class="bg-primary-100 mr-4 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <Mail class="text-primary-600 h-5 w-5" />
                </div>
                <div>
                  <h3 class="mb-1 font-medium text-gray-900">Email</h3>
                  <a
                    href={`mailto:${siteData.contact.email}`}
                    class="hover:text-primary-600 text-gray-600"
                  >
                    {siteData.contact.email}
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <div
                  class="bg-primary-100 mr-4 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <Phone class="text-primary-600 h-5 w-5" />
                </div>
                <div>
                  <h3 class="mb-1 font-medium text-gray-900">Phone</h3>
                  <a
                    href={`tel:${siteData.contact.phone.replace(/\D/g, "")}`}
                    class="hover:text-primary-600 text-gray-600"
                  >
                    {siteData.contact.phone}
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <div
                  class="bg-primary-100 mr-4 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <MapPin class="text-primary-600 h-5 w-5" />
                </div>
                <div>
                  <h3 class="mb-1 font-medium text-gray-900">Address</h3>
                  <p class="text-gray-600">
                    {siteData.contact.address}
                  </p>
                </div>
              </div>
            </div>

            <div class="mt-8">
              <h3 class="mb-4 font-medium text-gray-900">Business Hours</h3>
              <dl class="space-y-2 text-gray-600">
                <div class="flex justify-between">
                  <dt>Monday - Friday</dt>
                  <dd>9:00 AM - 5:00 PM</dd>
                </div>
                <div class="flex justify-between">
                  <dt>Saturday - Sunday</dt>
                  <dd>Closed</dd>
                </div>
              </dl>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="lg:col-span-2">
            <div class="rounded-lg bg-white p-8 shadow-sm">
              <h2 class="mb-6 text-2xl font-semibold text-gray-900">
                Send Us a Message
              </h2>
              <ContactForm />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
