# Site Configuration
PUBLIC_SITE_URL=https://CLIENT_NAME.socialtide.ai

# Form Handling Options (choose one)
# Option 1: Google Sheets
PUBLIC_GOOGLE_SHEETS_URL=

# Option 2: API Endpoint (e.g., SocialTide backend)
PUBLIC_API_ENDPOINT=

# Option 3: Cloudflare Turnstile (spam protection)
PUBLIC_TURNSTILE_SITE_KEY=

# Analytics
# Set in Cloudflare Workers environment variables for production
PUBLIC_POSTHOG_KEY=

