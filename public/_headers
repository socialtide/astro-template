/*
  # Security headers
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  
  # Content Security Policy
  # Allows: self, PostHog analytics, Google Fonts, Cloudflare, inline scripts/styles for Astro
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://us-assets.i.posthog.com https://ph.socialtide.ai https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://us.i.posthog.com https://ph.socialtide.ai; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Cache static assets aggressively
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache HTML pages for a short time
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Cache the homepage
/
  Cache-Control: public, max-age=300, must-revalidate

# Service worker (if used)
/sw.js
  Cache-Control: public, max-age=0, must-revalidate