/*
  # Security headers
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  
  # Content Security Policy
  # Fonts self-hosted via Astro 6 Fonts API — no external font domains needed
  # Allows: self, PostHog analytics, Cloudflare, Harbor backend
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://us-assets.i.posthog.com https://us.i.posthog.com https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://us.i.posthog.com https://us-assets.i.posthog.com https://harbor.socialtide.ai https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://harbor.socialtide.ai

# Cache static assets aggressively
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

# Cache HTML pages for a short time
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Cache the homepage
/
  Cache-Control: public, max-age=300, must-revalidate

# Service worker (if used)
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
